name: titanic-survival-prediction

conda_env: conda.yaml

entry_points:
  main:
    parameters:
      dataset_path:
        type: str
        default: "titanic_preprocessing.csv"
      n_estimators:
        type: int
        default: 100
      max_depth:
        type: int
        default: 5
    command: >
      python modelling_tuning.py
      --dataset {dataset_path}